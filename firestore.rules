rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Devices
    match /devices/{deviceId} {
      allow get: if isOwner(existing().ownerId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() 
                    && incoming().ownerId == request.auth.uid 
                    && incoming().name is string && incoming().name.size() <= 100
                    && incoming().type in ['Laptop', 'Desktop', 'Smartphone'];
      allow update: if isOwner(existing().ownerId) 
                    && incoming().ownerId == existing().ownerId
                    && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'type', 'status', 'risk', 'user', 'lastSeen']);
      allow delete: if isOwner(existing().ownerId);
    }

    // Vault
    match /vault/{itemId} {
      allow get: if isOwner(existing().ownerId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() 
                    && incoming().ownerId == request.auth.uid
                    && incoming().title is string && incoming().title.size() <= 100
                    && incoming().content is string && incoming().content.size() <= 5000;
      allow update: if isOwner(existing().ownerId)
                    && incoming().ownerId == existing().ownerId
                    && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'category', 'content']);
      allow delete: if isOwner(existing().ownerId);
    }

    // Team
    match /team/{memberId} {
      allow get: if isOwner(existing().ownerId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() 
                    && incoming().ownerId == request.auth.uid
                    && incoming().name is string && incoming().name.size() <= 100
                    && incoming().email is string && incoming().email.size() <= 100;
      allow update: if isOwner(existing().ownerId)
                    && incoming().ownerId == existing().ownerId
                    && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'role', 'status', 'email']);
      allow delete: if isOwner(existing().ownerId);
    }
  }
}
